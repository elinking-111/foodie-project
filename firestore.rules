rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function ownerEmailMatches() {
      return request.auth.token.email is string
        && hashing.sha256(request.auth.token.email.lower().toUtf8()).toHexString()
          == 'b2cdca73dbd2cc890e71e71cff0a62d7a77b91f6f8fb71c3882963b3487f9db9';
    }

    function isAdmin() {
      return request.auth != null
        && (
          request.auth.token.admin == true
          || ownerEmailMatches()
        );
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && request.resource.data.threadKey is string
        && request.resource.data.threadKey.size() > 0
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 2000
        && request.resource.data.authorUid == request.auth.uid;
      allow update, delete: if false;
    }

    match /likes/{likeId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.threadKey is string
        && request.resource.data.threadKey.size() > 0
        && request.resource.data.authorUid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.authorUid == request.auth.uid;
      allow update: if false;
    }

    match /placeEdits/{editId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /placeAdds/{addId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
